/wip
.pnpm-store
.alchemy/
.drive/projects/*/reviews/

# `prisma-compose deploy`/`destroy`'s generated stack file (deploy-cli.md) —
# regenerated every run, full of machine-local absolute paths.
.prisma-compose/
.makerkit/

# Local clone of prisma-next used as a scaffolding reference; not part of this repo.
/prisma-next/

# External reference checkouts, populated per-worktree by
# scripts/setup-worktree-refs.sh (never commit).
ignite/
pdp-control-plane/
prisma-next/
datahub/
open-chat/

# Shared bare-clone cache the setup script clones worktrees from.
.worktree-refs/

# Personal per-project Claude settings (holds the worktree-refs SessionStart hook).
.claude/settings.local.json

# Agent rules: the canonical, git-tracked home is `.agents/rules/*.mdc`. The
# `.cursor/rules` and `.claude/rules` trees are symlink mirrors regenerated by
# `pnpm rules:sync` (wired into `prepare`); ignore them so only canonical is tracked.
.cursor/rules
.claude/rules

# Agent skills are installed at `pnpm install` time, not vendored: `prepare` runs
# `skills add` to pull the consumed product skills from `prisma/skills` and the
# contributor skills from the tracked `skills-contrib/`. Ignore the generated
# install trees and the per-machine lock; `skills-contrib/` is the only tracked
# skill source.
.agents/skills/
.claude/skills/
skills-lock.json

# Next.js build output (any location — a stray copy under an unexpected path once got committed)
.next/
next-env.d.ts
