  "rules": {
    "sameLayer": "allow",
    "downward": "allow",
    "upward": "deny",
    "crossDomain": "directional",
    "controlToExecution": "deny",
    "executionToControl": "deny"
  },
  "crossDomainRules": {
    "framework": {
      "mayImportFrom": [],
      "reason": "0-framework is the innermost domain and imports nothing but external dependencies"
    },
    "prisma-cloud": {
      "mayImportFrom": ["framework"],
      "reason": "1-prisma-cloud may import 0-framework"
    },
    "public": {
      "mayImportFrom": ["framework", "prisma-cloud"],
      "reason": "9-public assembles both domains; nothing imports it (sink)"
    }
  },
  "planeRules": {
    "shared": {
      "allow": ["shared"],
      "forbid": ["control", "execution"],
      "exceptions": []
    },
    "control": {
      "allow": ["shared", "control"],
      "forbid": ["execution"],
      "exceptions": []
    },
    "execution": {
      "allow": ["shared", "execution"],
      "forbid": ["control"],
      "exceptions": []
    }
  },
  "crossDomainExceptions": [
    {
      "from": "packages/0-framework/3-tooling/cli/src/**",
      "to": "packages/1-prisma-cloud/0-lowering/lowering/src/**",
      "reason": "Known debt: the CLI's pre-stack container-ensure step (Project/Branch resolution) is Prisma Cloud-specific today; ADR-0017's config-driven model should eventually absorb it"
    }
  ],
  "layerOrder": {
    "framework": ["foundation", "core", "authoring", "tooling"],
    "prisma-cloud": ["lowering", "extensions", "modules"],
    "public": ["public"]
  }
}
