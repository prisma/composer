{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["TMPDIR"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", ".output/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "env": ["CI", "STATE_TEST_DATABASE_URL", "STATE_TEST_PG_TMPDIR"]
    },
    "test:types": {
      "dependsOn": ["^build", "build"]
    },
    "typecheck": {
      "dependsOn": ["^build", "build"]
    },
    "clean": {
      "cache": false
    }
  }
}
