{
  "name": "@internal/assemble",
  "version": "0.2.0",
  "type": "module",
  "description": "Deploy-only: routes each service to its build adapter's /assemble entry and applies the wrapper-inlining policy. Consumed by @prisma/composer-cli; the future programmatic deploy API is its second consumer.",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "tsdown",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@internal/core": "workspace:0.2.0"
  },
  "devDependencies": {
    "@internal/tsdown-config": "workspace:0.2.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.7",
    "typescript": "^6.0.3"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/compose.git",
    "directory": "packages/0-framework/3-tooling/assemble"
  },
  "engines": {
    "node": ">=24"
  },
  "private": true,
  "types": "./dist/index.d.mts"
}
