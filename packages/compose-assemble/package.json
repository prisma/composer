{
  "name": "@prisma/compose-assemble",
  "version": "0.3.0",
  "type": "module",
  "description": "Deploy-only: routes each service to its build adapter's /assemble entry and applies the wrapper-inlining policy. Consumed by @prisma/compose-cli; the future programmatic deploy API is its second consumer.",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@prisma/compose": "workspace:0.3.0"
  },
  "devDependencies": {
    "@prisma/compose-tsdown": "workspace:0.3.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "src"
  ],
  "types": "./dist/index.d.mts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/app.git",
    "directory": "packages/compose-assemble"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
