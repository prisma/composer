{
  "name": "@prisma/app-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The `prisma-app` deploy CLI. Runtime-agnostic (node >= 22.18 or bun); requires Node's default type stripping if run under node.",
  "bin": {
    "prisma-app": "./src/bin.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@prisma/app-assemble": "workspace:*",
    "@prisma/app": "workspace:*",
    "clipanion": "^3.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^24.10.13",
    "typescript": "^6.0.3"
  }
}
