{
  "name": "@prisma/app-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "The `prisma-app` deploy CLI.",
  "bin": {
    "prisma-app": "./dist/bin.mjs"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@prisma/app-assemble": "workspace:0.1.0",
    "@prisma/app": "workspace:0.1.0",
    "clipanion": "^3.2.1"
  },
  "devDependencies": {
    "@prisma/app-tsdown": "workspace:0.1.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^24.10.13",
    "tsdown": "^0.15.9",
    "typescript": "^6.0.3"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/app.git",
    "directory": "packages/app-cli"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
