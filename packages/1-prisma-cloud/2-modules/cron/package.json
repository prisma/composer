{
  "name": "@internal/cron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The cron Module: scheduled work as a driver (ADR-0020), realized on Prisma Cloud.",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./scheduler-service": {
      "types": "./dist/scheduler-service.d.mts",
      "default": "./dist/scheduler-service.mjs"
    },
    "./scheduler-entrypoint": {
      "types": "./dist/scheduler-entrypoint.d.mts",
      "default": "./dist/scheduler-entrypoint.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "build": "tsdown",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@internal/core": "workspace:0.1.0",
    "@internal/foundation": "workspace:0.1.0",
    "@internal/node": "workspace:0.1.0",
    "@internal/prisma-cloud": "workspace:0.1.0",
    "@internal/rpc": "workspace:0.1.0",
    "arktype": "^2.2.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18",
    "tsdown": "^0.22.3",
    "@internal/tsdown-config": "workspace:0.1.0"
  }
}
