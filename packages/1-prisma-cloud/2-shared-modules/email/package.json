{
  "name": "@internal/email",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Transactional email as a composed module: emailSendContract, emailOutboxContract, defineTemplates, the emailSender() dependency factory.",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./email-service": {
      "types": "./dist/email-service.d.mts",
      "default": "./dist/email-service.mjs"
    },
    "./email-entrypoint": {
      "types": "./dist/email-entrypoint.d.mts",
      "default": "./dist/email-entrypoint.mjs"
    },
    "./testing": {
      "types": "./dist/testing.d.mts",
      "default": "./dist/testing.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "build": "tsdown",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@internal/core": "workspace:0.2.0",
    "@internal/node": "workspace:0.2.0",
    "@internal/foundation": "workspace:0.2.0",
    "@internal/prisma-cloud": "workspace:0.2.0",
    "@internal/service-rpc": "workspace:0.2.0",
    "arktype": "^2.2.3",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@internal/tsdown-config": "workspace:0.2.0",
    "@types/bun": "^1.3.13",
    "@types/nodemailer": "^8.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "tsdown": "^0.22.7"
  }
}
