{
  "name": "@internal/storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "S3-compatible object storage (S5): s3Contract, S3Config, the s3() dependency factory.",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./storage-service": {
      "types": "./dist/storage-service.d.mts",
      "default": "./dist/storage-service.mjs"
    },
    "./storage-entrypoint": {
      "types": "./dist/storage-entrypoint.d.mts",
      "default": "./dist/storage-entrypoint.mjs"
    },
    "./testing": {
      "types": "./dist/testing.d.mts",
      "default": "./dist/testing.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "build": "tsdown",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@internal/core": "workspace:0.1.0",
    "@internal/node": "workspace:0.1.0",
    "@internal/prisma-cloud": "workspace:0.1.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18",
    "tsdown": "^0.22.3",
    "@internal/tsdown-config": "workspace:0.1.0"
  }
}
