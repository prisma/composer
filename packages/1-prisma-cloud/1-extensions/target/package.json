{
  "name": "@internal/prisma-cloud",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./control": {
      "types": "./dist/control.d.mts",
      "default": "./dist/control.mjs"
    },
    "./prisma-next": {
      "types": "./dist/prisma-next.d.mts",
      "default": "./dist/prisma-next.mjs"
    },
    "./testing": {
      "types": "./dist/testing.d.mts",
      "default": "./dist/testing.mjs"
    },
    "./connection": {
      "types": "./dist/pg-connection.d.mts",
      "default": "./dist/pg-connection.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:types": "vitest --typecheck --run",
    "build": "tsdown",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@internal/core": "workspace:0.1.0",
    "@internal/foundation": "workspace:0.1.0",
    "@internal/lowering": "workspace:0.1.0",
    "@internal/node": "workspace:0.1.0",
    "@internal/rpc": "workspace:0.1.0",
    "@prisma-next/cli": "0.14.0",
    "@prisma-next/contract": "0.14.0",
    "@prisma-next/migration-tools": "0.14.0",
    "@prisma-next/postgres": "0.14.0",
    "@prisma-next/sql-contract": "0.14.0",
    "@standard-schema/spec": "^1.1.0",
    "alchemy": "2.0.0-beta.59",
    "arktype": "^2.2.3",
    "effect": "4.0.0-beta.92",
    "pathe": "^2.0.3",
    "pg": "8.21.0"
  },
  "devDependencies": {
    "@prisma-next/target-postgres": "0.14.0",
    "@internal/tsdown-config": "workspace:0.1.0",
    "@types/bun": "^1.3.13",
    "@types/pg": "8.20.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/compose.git",
    "directory": "packages/1-prisma-cloud/1-extensions/target"
  },
  "engines": {
    "node": ">=24"
  },
  "private": true,
  "types": "./dist/index.d.mts"
}
