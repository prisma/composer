{
  "name": "prisma-compose",
  "version": "0.3.0",
  "type": "module",
  "description": "The prisma-compose CLI launcher — run `bunx prisma-compose` / `npx prisma-compose`.",
  "bin": {
    "prisma-compose": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/compose-cli": "workspace:0.3.0"
  },
  "devDependencies": {
    "@prisma/compose-tsdown": "workspace:0.3.0",
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/app.git",
    "directory": "packages/prisma-compose"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
