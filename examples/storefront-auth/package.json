{
  "name": "@makerkit/example-storefront-auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @makerkit/example-storefront-auth-auth build && pnpm --filter @makerkit/example-storefront-auth-storefront build:compute",
    "deploy": "pnpm build && ( set -a; . ../../.env; set +a; pnpm exec alchemy deploy --yes )",
    "destroy": "( set -a; . ../../.env; set +a; pnpm exec alchemy destroy --yes )"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.92",
    "@effect/platform-node-shared": "4.0.0-beta.92",
    "@makerkit/prisma-alchemy": "workspace:*",
    "alchemy": "2.0.0-beta.59",
    "effect": "4.0.0-beta.92"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
