{
  "name": "@makerkit/example-storefront-auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @storefront-auth/auth build && pnpm --filter @storefront-auth/storefront build:compute",
    "typecheck": "tsc --noEmit",
    "deploy": "pnpm build && ( set -a; . ../../.env; set +a; bunx --bun alchemy deploy --yes )",
    "destroy": "( set -a; . ../../.env; set +a; bunx --bun alchemy destroy --yes )"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.92",
    "@makerkit/core": "workspace:*",
    "@makerkit/prisma-alchemy": "workspace:*",
    "@makerkit/prisma-cloud": "workspace:*",
    "@makerkit/rpc": "workspace:*",
    "@storefront-auth/auth": "workspace:*",
    "@storefront-auth/storefront": "workspace:*",
    "alchemy": "2.0.0-beta.59",
    "arktype": "^2.2.3",
    "effect": "4.0.0-beta.92"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "tsdown": "^0.15.9",
    "typescript": "^6.0.3"
  }
}
